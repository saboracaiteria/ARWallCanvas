<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:keepScreenOn="true">

    <!-- Camera Preview usando CameraX PreviewView -->
    <androidx.camera.view.PreviewView
        android:id="@+id/preview_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Drawing Overlay (transparente, sobre a câmera) -->
    <com.arwallcanvas.ui.DrawingOverlayView
        android:id="@+id/drawing_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Color Picker (inicialmente oculto) -->
    <com.arwallcanvas.utils.ColorPicker
        android:id="@+id/color_picker"
        android:layout_width="320dp"
        android:layout_height="160dp"
        android:layout_gravity="center"
        android:visibility="gone"
        android:elevation="8dp" />

    <!-- Toolbar inferior -->
    <LinearLayout
        android:id="@+id/tool_bar"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:layout_gravity="bottom"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/toolbar_bg"
        android:paddingHorizontal="8dp"
        android:elevation="6dp">

        <!-- Botões de ferramentas -->
        <ImageButton
            android:id="@+id/btn_spray"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_spray"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/spray"
            android:alpha="0.4f"
            android:tint="#FFFFFF" />

        <ImageButton
            android:id="@+id/btn_brush"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_brush"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/brush"
            android:alpha="0.4f"
            android:tint="#FFFFFF" />

        <ImageButton
            android:id="@+id/btn_marker"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_marker"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/marker"
            android:alpha="0.4f"
            android:tint="#FFFFFF" />

        <ImageButton
            android:id="@+id/btn_eraser"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_eraser"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/eraser"
            android:alpha="0.4f"
            android:tint="#FFFFFF" />

        <View
            android:layout_width="1dp"
            android:layout_height="40dp"
            android:background="#33FFFFFF"
            android:layout_marginHorizontal="4dp" />

        <!-- Controle de Tamanho -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingHorizontal="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/size_label"
                android:textColor="#88FFFFFF"
                android:textSize="9sp"
                android:textStyle="bold" />

            <SeekBar
                android:id="@+id/size_slider"
                android:layout_width="match_parent"
                android:layout_height="32dp"
                android:max="95"
                android:progress="15"
                android:progressTint="#FFFFFF"
                android:thumbTint="#FFFFFF" />
        </LinearLayout>

        <View
            android:layout_width="1dp"
            android:layout_height="40dp"
            android:background="#33FFFFFF" />

        <!-- Controle de Opacidade -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingHorizontal="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/opacity_label"
                android:textColor="#88FFFFFF"
                android:textSize="9sp"
                android:textStyle="bold" />

            <SeekBar
                android:id="@+id/opacity_slider"
                android:layout_width="match_parent"
                android:layout_height="32dp"
                android:max="100"
                android:progress="80"
                android:progressTint="#FFFFFF"
                android:thumbTint="#FFFFFF" />
        </LinearLayout>

        <View
            android:layout_width="1dp"
            android:layout_height="40dp"
            android:background="#33FFFFFF"
            android:layout_marginHorizontal="4dp" />

        <!-- Botões de ação -->
        <ImageButton
            android:id="@+id/btn_undo"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_undo"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/undo"
            android:tint="#FFFFFF" />

        <ImageButton
            android:id="@+id/btn_redo"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_redo"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/redo"
            android:tint="#FFFFFF" />

        <ImageButton
            android:id="@+id/btn_color"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_color"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/color"
            android:tint="#FFFFFF" />

        <ImageButton
            android:id="@+id/btn_clear"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_clear"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/clear"
            android:tint="#FFFFFF" />

        <ImageButton
            android:id="@+id/btn_save"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_save"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/save"
            android:tint="#FFFFFF" />

    </LinearLayout>

</FrameLayout>
